# Environment variables for running history-service locally against docker-local services.
# Copy to .env and adjust if needed:
#   cp .env.example .env
#
# Usage from repo root:
#   set -a && source history-service/docker-local/.env && set +a
#   go run ./history-service/cmd/

NATS_URL=nats://localhost:4222
MONGO_URI=mongodb://localhost:27017
MONGO_DB=chat
CASSANDRA_HOSTS=localhost
CASSANDRA_KEYSPACE=chat
SITE_ID=site-local
