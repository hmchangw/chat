{
  "title": "Loadgen",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "Throughput (msg/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "rate(loadgen_published_total[10s])", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "E1 gatekeeper latency (P50/P95/P99)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(loadgen_e1_latency_seconds_bucket[30s])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(loadgen_e1_latency_seconds_bucket[30s])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(loadgen_e1_latency_seconds_bucket[30s])) by (le))", "legendFormat": "p99", "refId": "C"}
      ]
    },
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "E2 broadcast latency (P50/P95/P99)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(loadgen_e2_latency_seconds_bucket[30s])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(loadgen_e2_latency_seconds_bucket[30s])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(loadgen_e2_latency_seconds_bucket[30s])) by (le))", "legendFormat": "p99", "refId": "C"}
      ]
    },
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "Consumer pending",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "loadgen_consumer_pending", "legendFormat": "{{durable}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "Consumer ack pending",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [{"expr": "loadgen_consumer_ack_pending", "legendFormat": "{{durable}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "Publish errors/sec",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [{"expr": "rate(loadgen_publish_errors_total[10s])", "legendFormat": "{{reason}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "Read scenarios — request rate by kind",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [{"expr": "sum by (scenario, kind) (rate(loadgen_requests_total[10s]))", "legendFormat": "{{scenario}}.{{kind}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "Read scenarios — request latency p99",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "targets": [
        {"expr": "histogram_quantile(0.99, sum by (scenario, kind, le) (rate(loadgen_request_latency_seconds_bucket[30s])))", "legendFormat": "{{scenario}}.{{kind}} p99", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "Read scenarios — request latency p50/p95",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (scenario, kind, le) (rate(loadgen_request_latency_seconds_bucket[30s])))", "legendFormat": "{{scenario}}.{{kind}} p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (scenario, kind, le) (rate(loadgen_request_latency_seconds_bucket[30s])))", "legendFormat": "{{scenario}}.{{kind}} p95", "refId": "B"}
      ]
    },
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "Read scenarios — request errors/sec",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "targets": [{"expr": "sum by (scenario, kind, reason) (rate(loadgen_request_errors_total[10s]))", "legendFormat": "{{scenario}}.{{kind}}.{{reason}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "title": "Saturation events/sec (all scenarios)",
      "description": "Unified saturation view: messaging-pipeline saturation lives in loadgen_publish_errors_total{reason=saturated}; read-scenario saturation lives in loadgen_request_errors_total{reason=saturated}. This panel sums both so loadgen-side pressure is visible regardless of scenario.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 40},
      "targets": [
        {"expr": "sum(rate(loadgen_publish_errors_total{reason=\"saturated\"}[10s])) + sum(rate(loadgen_request_errors_total{reason=\"saturated\"}[10s]))", "legendFormat": "saturated/s", "refId": "A"}
      ]
    }
  ]
}
