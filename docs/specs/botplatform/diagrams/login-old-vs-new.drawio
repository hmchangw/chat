<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="login-old-vs-new">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Bot Login — Old vs New Mechanism" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#263238;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="1800" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Side-by-side: legacy Rocket.Chat / Meteor (capped session array + plain SHA-256) vs nextgen botplatform-service (provisioning gate + bp1_ prefix + HMAC-keyed storage)" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#546E7A;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="50" width="1800" height="20" as="geometry" />
        </mxCell>

        <!-- LEFT panel: OLD -->
        <mxCell id="old" value="OLD — Legacy Rocket.Chat / Meteor   (today, fz2/chat)" style="swimlane;startSize=36;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=14;fontStyle=1;fontColor=#B71C1C;swimlaneFillColor=#FFF5F5;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="930" height="1050" as="geometry" />
        </mxCell>

        <mxCell id="o_step1" value="Step 1   Bot dials legacy URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="old">
          <mxGeometry x="40" y="60" width="850" height="80" as="geometry" />
        </mxCell>
        <mxCell id="o_step1_body" value="POST /api/v1/login&#xa;body: { user, password }   (plaintext or RC digest form)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="old">
          <mxGeometry x="60" y="85" width="810" height="50" as="geometry" />
        </mxCell>

        <mxCell id="o_step2" value="Step 2   Server reads users.services.password.bcrypt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="old" parent="1">
          <mxGeometry x="100" y="260" width="850" height="80" as="geometry" />
        </mxCell>
        <mxCell id="o_step2_body" value="bcrypt.compare( bcrypt_hash, sha256_hex(plaintext) )&#xa;NO provisioning gate — if creds match, login succeeds anywhere" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="old">
          <mxGeometry x="60" y="285" width="810" height="50" as="geometry" />
        </mxCell>

        <mxCell id="o_step3" value="Step 3   Issue opaque random token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="old">
          <mxGeometry x="40" y="360" width="850" height="100" as="geometry" />
        </mxCell>
        <mxCell id="o_step3_body" value="raw = randomString(43 chars)&#xa;hashed = base64( sha256(raw) )                        ← plain SHA-256, public hash function&#xa;wire format = bare random string (no prefix)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="old">
          <mxGeometry x="60" y="385" width="810" height="70" as="geometry" />
        </mxCell>

        <mxCell id="o_step4" value="Step 4   Append to capped loginTokens[] array" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="old">
          <mxGeometry x="40" y="480" width="850" height="120" as="geometry" />
        </mxCell>
        <mxCell id="o_step4_body" value="db.users.update( { _id }, { $push:&#xa;  { &quot;services.resume.loginTokens&quot;: { when, hashedToken } } } )&#xa;&#xa;⚠ array is CAPPED at 50 — older tokens fall off the end" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="old">
          <mxGeometry x="60" y="505" width="810" height="90" as="geometry" />
        </mxCell>

        <mxCell id="o_step5" value="Step 5   Return RC envelope" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C62828;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="old">
          <mxGeometry x="40" y="620" width="850" height="100" as="geometry" />
        </mxCell>
        <mxCell id="o_step5_body" value="{ status:&#x27;success&#x27;, data:{ authToken, userId, me:{ ..., roles:[&#x27;bot&#x27;] } } }&#xa;subsequent calls: X-Auth-Token + X-User-Id headers" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="old">
          <mxGeometry x="60" y="645" width="810" height="70" as="geometry" />
        </mxCell>

        <mxCell id="o_problems" value="Problems with the old mechanism" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="old">
          <mxGeometry x="40" y="740" width="850" height="280" as="geometry" />
        </mxCell>
        <mxCell id="o_problems_body" value="• Capped at 50 sessions per user — O(n) array scan per validate&#xa;• No provisioning gate — valid creds anywhere = login anywhere&#xa;• Plain SHA-256 storage — DB dump lets attacker probe hashes&#xa;• No version prefix — cannot rotate token format without DB migration&#xa;• Token leaked in logs = direct lookup key (no server-side secret)&#xa;• Single-site / monolithic — no concept of home site" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="old">
          <mxGeometry x="60" y="770" width="810" height="240" as="geometry" />
        </mxCell>

        <!-- RIGHT panel: NEW -->
        <mxCell id="new" value="NEW — botplatform-service   (nextgen, fz1/wsp)" style="swimlane;startSize=36;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=14;fontStyle=1;fontColor=#1B5E20;swimlaneFillColor=#F1F8E9;" vertex="1" parent="1">
          <mxGeometry x="1010" y="100" width="930" height="1050" as="geometry" />
        </mxCell>

        <mxCell id="n_step1" value="Step 1   Bot dials site-scoped URL (SAME path)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="new">
          <mxGeometry x="40" y="60" width="850" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n_step1_body" value="POST /api/v1/login   (legacy contract preserved — zero bot code changes)&#xa;body: { user: &#x27;xxx.bot&#x27;, password }   (same plaintext or RC digest form)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="new">
          <mxGeometry x="60" y="85" width="810" height="50" as="geometry" />
        </mxCell>

        <mxCell id="n_step2" value="Step 2   Validate format + verify password" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="new">
          <mxGeometry x="40" y="160" width="850" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n_step2_body" value="IsValidBotAccount(&#x27;xxx.bot&#x27;)                ← reject malformed before DB hit&#xa;load credentials by account (Mongo)&#xa;bcrypt.CompareHashAndPassword(...)             constant-time + dummy compare on miss" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="new">
          <mxGeometry x="60" y="185" width="810" height="70" as="geometry" />
        </mxCell>

        <mxCell id="n_step3" value="Step 3   PROVISIONING GATE   (NEW — mirrors PR #295)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="new">
          <mxGeometry x="40" y="280" width="850" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n_step3_body" value="db.users.findOne({ account, siteId: SITE_ID })&#xa;not found → 403 account_not_provisioned     (fail-closed on store error)&#xa;REQUIRE_PROVISIONED=true default; mis-pointed bot at wrong site cannot log in" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="new">
          <mxGeometry x="60" y="305" width="810" height="70" as="geometry" />
        </mxCell>

        <mxCell id="n_step4" value="Step 4   Issue v1 token   (NEW format)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="new">
          <mxGeometry x="40" y="400" width="850" height="120" as="geometry" />
        </mxCell>
        <mxCell id="n_step4_body" value="raw  = &quot;bp1_&quot; + base64url( crypto/rand.Read(32) )       ← 256-bit entropy, versioned prefix&#xa;hash = base64( HMAC-SHA-256( TOKEN_HMAC_KEY, raw ) )   ← keyed hash, server-side secret&#xa;wire format = bp1_&lt;43-char base64url&gt;   (47 chars total)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="new">
          <mxGeometry x="60" y="425" width="810" height="90" as="geometry" />
        </mxCell>

        <mxCell id="n_step5" value="Step 5   INSERT into sessions   (one doc per session)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="new">
          <mxGeometry x="40" y="540" width="850" height="120" as="geometry" />
        </mxCell>
        <mxCell id="n_step5_body" value="db.sessions.insertOne({ _id: hash, userId, account, siteId, scheme:&#x27;v1&#x27;,&#xa;                       issuedAt, lastUsedAt, expiresAt: now + 180d })&#xa;✓ unlimited sessions per account (no cap)        ✓ O(1) lookup by _id" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="new">
          <mxGeometry x="60" y="565" width="810" height="90" as="geometry" />
        </mxCell>

        <mxCell id="n_step6" value="Step 6   Warm Valkey cache + return RC-compatible envelope" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="new">
          <mxGeometry x="40" y="680" width="850" height="120" as="geometry" />
        </mxCell>
        <mxCell id="n_step6_body" value="SETEX valkey  hash  →  principal  (TTL 5m, hot path for validate)&#xa;{ status:&#x27;success&#x27;, data:{ authToken:&#x27;bp1_…&#x27;, userId, me } }&#xa;subsequent calls: X-Auth-Token + X-User-Id  (SAME header shape)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="new">
          <mxGeometry x="60" y="705" width="810" height="90" as="geometry" />
        </mxCell>

        <mxCell id="n_wins" value="What the new mechanism wins" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="new">
          <mxGeometry x="40" y="820" width="850" height="200" as="geometry" />
        </mxCell>
        <mxCell id="n_wins_body" value="✓ Unlimited sessions per account — O(1) lookup by token hash _id&#xa;✓ Provisioning gate — login only at the bot&#x27;s home site&#xa;✓ HMAC-keyed storage — DB dump is opaque without TOKEN_HMAC_KEY&#xa;✓ Versioned wire format (bp1_) — forward rotation, secret-scanner detection&#xa;✓ Hot path served from Valkey (1M validations/min target, &lt;5ms cached)&#xa;✓ Multi-site native, with per-site sessions / credentials / users isolation" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="new">
          <mxGeometry x="60" y="850" width="810" height="160" as="geometry" />
        </mxCell>

        <!-- Bottom: backward compat callout -->
        <mxCell id="compat" value="Backward compatibility — what stays IDENTICAL on the wire" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=12;fontStyle=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="1170" width="1880" height="100" as="geometry" />
        </mxCell>
        <mxCell id="compat_body" value="• Path: POST /api/v1/login   (legacy contract)         • Body shape: { user, password } plaintext or { digest, algorithm:&#x27;sha-256&#x27; }         • Response envelope: { status, data:{ authToken, userId, me:{...} } }&#xa;• Headers: X-Auth-Token + X-User-Id                    • User ID: 17-char Meteor base62 preserved verbatim         • Migrated tokens: imported byte-for-byte, scheme:&#x27;legacy&#x27;, still validate after cutover&#xa;Result: bots run unchanged — no SDK redeploy, no credential reset, no URL change. Same wire surface, new server-side mechanics." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="1200" width="1840" height="65" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
