# docker-local/e2e/.env.example
#
# Copied to docker-local/e2e/.env on first run by `make e2e-up` (idempotent).
# Edit the .env (NOT .env.example) to override image refs for an internal
# registry mirror. The .env is gitignored.
#
# Defaults below are upstream Docker Hub references that work for a fresh
# clone with public registry access.

E2E_NATS_IMAGE=nats:2.11-alpine
E2E_MONGO_IMAGE=mongo:8
E2E_CASS_IMAGE=cassandra:5
E2E_ES_IMAGE=elasticsearch:8.17.0
E2E_VALKEY_IMAGE=valkey/valkey:8
E2E_KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.0
